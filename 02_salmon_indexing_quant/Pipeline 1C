# This script performs differential expression analysis at the individual transcript level using edgeR, voom normalisation, and limma.

# 1. Package installation & activation

# Install Bioconductor manager if not present
if (!requireNamespace("BiocManager", quietly = TRUE)) {
  install.packages("BiocManager")
}

# Install required Bioconductor packages
# BiocManager::install(c("tximport", "edgeR", "limma", "pheatmap"))

# Install standard CRAN packages
# install.packages(c("tidyverse", "ggplot2", "reshape2", "ggrepel"))

library(tximport)
library(edgeR)
library(limma)
library(tidyverse)
library(ggplot2)
library(pheatmap)
library(reshape2)
library(ggrepel)

# Clean environment
rm(list = ls())
graphics.off()

# 2. Workspace setup & metadata

# Set working directory (Update to your local working directory)
setwd("<working_dir>/03_Salmon_FASTQ_Voom_Limma")

# Define sample metadata
metadata <- data.frame(
  Sample = c("BC09","BC10","BC11","BC13","BC15","BC16"),
  Condition = c("WT","WT","WT","Mdx","Mdx","Mdx"),
  label = c("WT5","WT6","WT14","Mdx2","Mdx15","Mdx90")
)
rownames(metadata) <- metadata$Sample

# 3. Data import (Salmon .sf Files)
files <- list.files(
  "<input_salmon_fastq_dir>",
  pattern = "quant_.*\\.sf$",
  full.names = TRUE
)

# Assign clean sample names
names(files) <- gsub("quant_|\\.sf", "", basename(files))

# Import transcript-level counts keeping transcript resolution (txOut = TRUE)
txi <- tximport(files, type = "salmon", txOut = TRUE)
counts <- txi$counts

# 4. edgeR preprocessing & filtering

# Construct DGEList object
dge <- DGEList(counts)

# Calculate Counts Per Million (CPM)
cpm_values <- cpm(dge)

# Apply filtering: Keep transcripts with CPM > 1 in at least 3 samples
keep <- rowSums(cpm_values > 1) >= 3
dge <- dge[keep, ]

# Apply TMM (Trimmed Mean of M-values) normalisation
dge <- calcNormFactors(dge, method = "TMM")

# 5. Voom transformation & Limma modeling

group <- factor(metadata$Condition)

# Set up design matrix
design <- model.matrix(~0 + group)
colnames(design) <- levels(group)   # WT, Mdx

# Apply voom transformation to model mean-variance relationship
v <- voom(dge, design, plot = TRUE)

# Fit linear model
fit <- lmFit(v, design)

# Define contrast matrix (Mdx vs WT)
contrast.matrix <- makeContrasts(
  Mdx_vs_WT = Mdx - WT,
  levels = design
)

fit2 <- contrasts.fit(fit, contrast.matrix)
fit2 <- eBayes(fit2)

# Extract differential expression statistics
res <- topTable(
  fit2,
  coef = "Mdx_vs_WT",
  number = Inf
)
res$Gene <- rownames(res)

# 6. Data visualization

# --- Violin Plot ---
logCPM <- v$E
df <- as.data.frame(logCPM)
df$Gene <- rownames(df)

df <- melt(df, id.vars = "Gene")
colnames(df) <- c("Gene", "Sample", "Expression")

df$Condition <- metadata[df$Sample, "Condition"]
df$Label <- metadata[df$Sample, "label"]

# Set factor levels for consistent sample ordering
df$Label <- factor(df$Label, levels = c("WT5","WT6","WT14","Mdx2","Mdx15","Mdx90"))

p_violin <- ggplot(df, aes(x = Label, y = Expression, fill = Condition)) +
  geom_violin(alpha = 0.7, trim = TRUE, color = "black") +
  scale_fill_manual(values = c(
    "WT" = "skyblue",
    "Mdx" = "maroon4"
  )) +
  coord_cartesian(ylim = c(
    quantile(df$Expression, 0.01),
    quantile(df$Expression, 0.99)
  )) +
  theme_bw() +
  labs(
    title = "Expression Distribution across Samples (logCPM)",
    x = "Sample",
    y = "logCPM"
  ) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    plot.title = element_text(hjust = 0.5)
  )
print(p_violin)

# --- Volcano Plot ---
res_df <- as.data.frame(res)
res_df$Gene <- rownames(res_df)

# Define significance thresholds
res_df$Significant <- ifelse(
  res_df$adj.P.Val < 0.05 & abs(res_df$logFC) > 1,
  "YES",
  "NO"
)

p_volcano <- ggplot(res_df, aes(logFC, -log10(adj.P.Val), color = Significant)) +
  geom_point(alpha = 0.7, size = 1.5) +
  geom_hline(
    yintercept = -log10(0.05),
    linetype = "dashed",
    color = "black",
    linewidth = 0.5
  ) +
  geom_vline(
    xintercept = c(-1, 1),
    linetype = "dashed",
    color = "black",
    linewidth = 0.5
  ) +
  scale_color_manual(values = c(
    "NO" = "grey70",
    "YES" = "#D55E00"
  )) +
  theme_bw() +
  labs(
    title = "Differential Expression Volcano Plot",
    x = "log2 Fold Change",
    y = "-log10(adj.P.Val)",
    color = "Significant"
  ) +
  theme(plot.title = element_text(hjust = 0.5))
print(p_volcano)

# 7. Heatmap of Differentially Expressed Transcripts (DETs)

res_df$DEG_flag <- res_df$adj.P.Val < 0.05 & abs(res_df$logFC) > 1
res_df$Up_in <- ifelse(res_df$logFC > 0, "Mdx", "WT")

sig <- res_df$Gene[res_df$DEG_flag == TRUE]
mat <- logCPM[sig,]

metadata_ordered <- metadata[colnames(mat), ]
colnames(mat) <- metadata_ordered$label

# Reorder matrix columns to match requested layout
orden <- c("WT5","WT6","WT14","Mdx2","Mdx15","Mdx90")
mat <- mat[, orden]

# Plot Heatmap if DEGs are present
if (nrow(mat) > 1) {
  pheatmap(
    mat,
    scale = "row",
    fontsize_row = 2,
    fontsize_col = 10,
    cluster_cols = TRUE,
    show_rownames = FALSE
  )
} else {
  cat("No hay suficientes DEGs para heatmap\n")
}

# 8. Data export

# Export all stats with significance flags
write.csv2(
  res_df,
  "All_genes_with_DEG_flag_Voom_Limma.csv",
  row.names = FALSE
)

# Export normalised logCPM expression matrix
expr_df <- as.data.frame(logCPM)
expr_df$Gene <- rownames(expr_df)
expr_df <- expr_df[, c("Gene", colnames(logCPM))]

write.csv2(
  expr_df,
  "Expression_matrix_logCPM_Voom_Limma.csv",
  row.names = FALSE
)
