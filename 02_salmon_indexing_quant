# 01_Salmon_indexing
conda activate salmon

# Reference transcriptome from NCBI dataset is required
salmon index \
  -t "<reference_transcriptome_dir>/rna.fna" \
  -i "<output_dir>/04_salmon/salmon_index" \
  -p 8

# Template command for an individual barcode quantification
salmon quant \
  -i "<output_dir>/04_salmon/salmon_index" \
  -l A \
  -r "<output_dir>/03_fastq_output/<sample_barcode>.fastq" \
  -o "<output_dir>/04_salmon/<barcode_ID>" \
  -p 8

# 02_Select_pipeline
# Once the Salmon .sf files are obstained, you can move onto RStudio to proceed, with the three variants of Pipeline 1 (1A, 1B and 1C)

# ==============================================================================
# PIPELINE 1A: TRANSCRIPT QUANTIFICATION (TPM-BASED EXPLORATORY ANALYSIS)
# This script performs exploratory analysis of transcript-level abundance using Salmon's TPM values.
# ==============================================================================

# Load required libraries
library(tidyverse)
library(reshape2)
library(ggplot2)
library(dplyr)

# Set working directory (Update to your local/working directory if needed)
setwd("<output_dir>/01_Salmon_FASTQ_TPM")

# Define sample metadata
metadata <- data.frame(
  Sample = c("BC09","BC10","BC11","BC13","BC15","BC16"),
  Condition = c("WT","WT","WT","Mdx","Mdx","Mdx"),
  label = c("WT5","WT6","WT14","Mdx2","Mdx15","Mdx90")
)
rownames(metadata) <- metadata$Sample

# Locate Salmon output .sf files
files <- list.files(
  "<input_salmon_fastq_dir>",
  pattern = "quant_.*\\.sf$",
  full.names = TRUE
)

# Extract sample names from file paths
Samples <- gsub("quant_|\\.sf", "", basename(files))

# Import and merge TPM data from all samples
tpm_list <- lapply(files, function(f){
  read.delim(f) %>%
    dplyr::select(Name, TPM)
})

merged <- Reduce(function(x, y) full_join(x, y, by = "Name"), tpm_list)
colnames(merged) <- c("Gene", Samples)
rownames(merged) <- merged$Gene
merged <- merged[, -1]

# Format as matrix and handle missing values
tpm <- as.matrix(merged)
tpm[is.na(tpm)] <- 0

# Perform log2 transformation for visualization
log_tpm <- log2(tpm + 1)

# Reshape data for ggplot2
df <- melt(log_tpm)
colnames(df) <- c("Gene", "Sample", "Expression")

df$Label <- metadata[df$Sample, "label"]
df$Condition <- metadata[df$Sample, "Condition"]

# Set factor levels for consistent sample ordering
orden <- c("WT5", "WT6", "WT14", "Mdx2", "Mdx15", "Mdx90")
df$Label <- factor(df$Label, levels = orden)

# Set limits for expression distribution
y_min <- 0
y_max <- 1

# Plot 1: Violin Plot

p1 <- ggplot(df, aes(Label, Expression, fill = Condition)) +
  geom_violin(alpha = 0.7, trim = TRUE, color = "black") +
  scale_fill_manual(values = c(
    "WT" = "skyblue",
    "Mdx" = "maroon4"
  )) +
  coord_cartesian(ylim = c(y_min, y_max)) +
  theme_bw() +
  labs(
    x = "Sample",
    y = "Expression"
  ) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    plot.title = element_text(hjust = 0.5)
  )

print(p1)

# Plot 2: Intra-sample visualization of relative abundance (Top 30 transcripts)

# Specify target sample for intra-sample visualization (e.g., "BC09")
target_sample <- "<target_sample_ID>" 

tpm_target <- data.frame(
  Transcript = rownames(tpm),
  TPM = tpm[, target_sample]
)

top_genes_target <- tpm_target %>%
  filter(TPM > 0) %>%
  arrange(desc(TPM)) %>%
  slice_head(n = 30)

p_intra_sample <- ggplot(top_genes_target, aes(x = reorder(Transcript, TPM), y = TPM)) +
  geom_bar(stat = "identity", fill = "skyblue", alpha = 0.85) + 
  coord_flip() + 
  theme_minimal(base_size = 11) +
  labs(
    title = paste("Intra-sample visualization of relative abundance (Sample:", target_sample, ")"),
    x = "Transcripts",
    y = "Expression in Transcripts Per Million (TPM)"
  ) +
  theme(
    plot.title = element_text(face = "bold", size = 12),
    panel.grid.minor = element_blank(),
    axis.text.y = element_text(size = 8)
  )

print(p_intra_sample)
