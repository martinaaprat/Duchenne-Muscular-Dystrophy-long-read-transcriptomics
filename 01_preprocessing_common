# 01_Basecalling

conda activate dorado

dorado basecaller \
  <path_to_dorado_model_dir>/dna_r10.4.1_e8.2_400bps_sup@v4.2.0 \
  "<input_pod5_dir>" \
  --kit-name SQK-PCB114-24 \
  > "<output_dir>/01_basecalling/calls.bam"


# 02_Demultiplexing

dorado demux \
  --output-dir "<output_dir>/02_barcoding" \
  --no-classify \
  "<input_dir>/01_basecalling/calls.bam"


# 03_Formating

conda activate samtools_env

for bam in <output_dir>/02_barcoding/*.bam; do
  base=$(basename "$bam" .bam)
  samtools fastq "$bam" > "<output_dir>/03_fastq_output/${base}.fastq"
done


# 04_Quality_check 

conda activate nanoplot

# Template command for an individual barcode/sample

NanoPlot \
  --fastq "<output_dir>/03_fastq_output/<sample_barcode>.fastq" \
  --loglength \
  --plots hex dot \
  -o "<output_dir>/04_QC_fastq/<barcode_ID>/"
